{
  "name": "neet-demo-system",
  "version": "1.0.0",
  "description": "NEET UG Test Platform for coaching classes",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "seed:teacher": "cd server && node scripts/seedTeacher.js",
    "seed:questions": "cd server && node scripts/seedQuestions.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
